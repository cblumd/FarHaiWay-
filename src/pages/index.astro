<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FarHaiWay</title>
</head>
<body>

  <div class="min-h-screen bg-gradient-to-br from-[#006994] to-[#E0F7FA] p-8 font-sans overflow-hidden">
    
    <div class="absolute -left-10 -bottom-10 opacity-40 pointer-events-none transform scale-110">
      <svg width="300" height="400" viewBox="0 0 100 140" fill="none" stroke="#9DC183" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M45 140 Q30 80 45 30" />
        <path d="M55 140 Q40 80 45 30" />
        <path d="M42 120 L52 120" />
        <path d="M39 100 L49 100" />
        <path d="M38 80 L46 80" />
        <path d="M40 60 L45 60" />
        <path d="M42 45 L46 45" />
        <path d="M45 30 Q15 10 0 35" />
        <path d="M45 30 Q80 15 95 30" />
        <path d="M45 30 Q10 40 5 70" />
        <path d="M45 30 Q85 45 85 75" />
        <path d="M45 30 Q25 65 30 90" />
        <path d="M45 30 Q65 65 60 90" />
        <path d="M45 30 Q45 -5 60 10" />
      </svg>
    </div>

    <div class="absolute -right-10 -bottom-10 opacity-40 pointer-events-none transform scale-110 -scale-x-100 rotate-6">
      <svg width="300" height="400" viewBox="0 0 100 140" fill="none" stroke="#9DC183" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M45 140 Q30 80 45 30" />
        <path d="M55 140 Q40 80 45 30" />
        <path d="M42 120 L52 120" />
        <path d="M39 100 L49 100" />
        <path d="M38 80 L46 80" />
        <path d="M40 60 L45 60" />
        <path d="M42 45 L46 45" />
        <path d="M45 30 Q15 10 0 35" />
        <path d="M45 30 Q80 15 95 30" />
        <path d="M45 30 Q10 40 5 70" />
        <path d="M45 30 Q85 45 85 75" />
        <path d="M45 30 Q25 65 30 90" />
        <path d="M45 30 Q65 65 60 90" />
        <path d="M45 30 Q45 -5 60 10" />
      </svg>
    </div>

    <nav class="relative z-10 flex justify-between items-center text-[#F4E4BC]">
      <label for="menu-toggle" class="text-3xl font-bold cursor-pointer hover:text-white select-none">☰</label>
      
      <div class="flex gap-4 font-bold">
        <label for="lang-en" class="cursor-pointer hover:underline select-none">EN</label>
        <label for="lang-th" class="cursor-pointer hover:underline select-none">TH</label>
        <label for="lang-ch" class="cursor-pointer hover:underline select-none">CH</label>
      </div>
    </nav>

    <input type="checkbox" id="menu-toggle" class="peer/menu hidden">

    <div class="hidden peer-checked/menu:block absolute top-20 left-8 z-20 bg-[#F4E4BC] p-6 rounded-lg text-[#006994] shadow-xl w-48">
      <ul class="space-y-4 font-bold text-lg">
        <li><a href="/china" class="hover:text-black block">China</a></li>
        <li><a href="/thailand" class="hover:text-black block">Thailand</a></li>
        <li><a href="/usa" class="hover:text-black block">USA</a></li>
      </ul>
    </div>

    <div class="relative z-0 flex flex-col items-center justify-center h-[70vh] text-center">
      
      <input type="radio" name="language" id="lang-en" class="peer/en hidden" checked>
      <input type="radio" name="language" id="lang-th" class="peer/th hidden">
      <input type="radio" name="language" id="lang-ch" class="peer/ch hidden">

      <div class="hidden peer-checked/en:block">
        <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">FarHaiWay</h1>
        <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">Check out my adventures</p>
      </div>

      <div class="hidden peer-checked/th:block">
        <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">FarHaiWay</h1>
        <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">ตรวจสอบการผจญภัยของฉัน</p>
      </div>

      <div class="hidden peer-checked/ch:block">
        <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">远海之路</h1>
        <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">看看我的冒险</p>
      </div>

    </div>
  </div>

</body>
</html>

---
import MainLayout from '../layouts/MainLayout.astro';

const menuItems = [
  { label: 'China',    href: '/china'    },
  { label: 'Thailand', href: '/thailand' },
  { label: 'USA',      href: '/usa'      },
  { separator: true },
  { label: '← Home', href: '/' },
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
];

const sections = [
  {
    country: 'China',
    cities: [
      { name: 'Zhuhai',    sub: 'Guangdong', href: '/china/zhuhai/gallery'    },
      { name: 'Guangzhou', sub: 'Guangdong', href: '/china/guangzhou/gallery' },
      { name: 'Shenzhen',  sub: 'Guangdong', href: '/china/shenzhen/gallery'  },
      { name: 'Hong Kong', sub: 'SAR',       href: '/china/hongkong/gallery'  },
      { name: 'Macau',     sub: 'SAR',       href: '/china/macau/gallery'     },
    ],
  },
  {
    country: 'Thailand',
    cities: [
      { name: 'Bangkok',    sub: 'Central', href: '/thailand/bangkok/gallery'    },
      { name: 'Nonthaburi', sub: 'Greater BKK', href: '/thailand/nonthaburi/gallery' },
      { name: 'Koh Samet',  sub: 'Rayong', href: '/thailand/kohsamet/gallery'   },
    ],
  },
  {
    country: 'USA',
    cities: [
      { name: 'Broomfield', sub: 'Colorado', href: '/usa/broomfield/gallery' },
      { name: 'Boulder',    sub: 'Colorado', href: '/usa/boulder/gallery'    },
      { name: 'Denver',     sub: 'Colorado', href: '/usa/denver/gallery'     },
    ],
  },
];
---

<MainLayout title="Full Gallery | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Language Radio Inputs (Kept at top level for CSS targeting) -->
  <input type="radio" name="lang-peer" id="lang-en" class="hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="hidden" />

  <div class="content-wrapper">
    <!-- Fixed Night Globe Background (Copied from Landing Page) -->
    <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
      <img 
        src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2000&auto=format&fit=crop" 
        alt="Earth at night" 
        class="w-full h-full object-cover opacity-60 mix-blend-screen"
      />
      <!-- Gradients to blend the edges and improve text readability -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/95 via-[#121212]/40 to-[#121212]/90"></div>
    </div>

    <!-- Triple-flag watermark (styled for dark theme) -->
    <div slot="watermark" class="absolute inset-0 z-0 pointer-events-none flex items-start justify-between px-16 pt-10 opacity-10">
      <!-- China -->
      <div class="transform scale-125 origin-top-left">
        <svg width="160" height="120" viewBox="0 0 300 200" fill="#C5A059">
          <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(1.5) translate(10,15)" />
        </svg>
      </div>
      <!-- Thailand -->
      <div class="transform scale-125 origin-top blur-[1px]">
        <svg width="160" height="120" viewBox="0 0 300 200" preserveAspectRatio="none">
          <rect width="300" height="33"  fill="#A51931" />
          <rect y="33"  width="300" height="33" fill="#F4F5F8" />
          <rect y="66"  width="300" height="68" fill="#2D2A4A" />
          <rect y="134" width="300" height="33" fill="#F4F5F8" />
          <rect y="167" width="300" height="33" fill="#A51931" />
        </svg>
      </div>
      <!-- USA -->
      <div class="transform scale-125 origin-top-right blur-[1px]">
        <svg width="160" height="120" viewBox="0 0 300 200" preserveAspectRatio="none">
          <rect width="300" height="200" fill="#B22234" />
          <rect y="15"   width="300" height="15" fill="#FFFFFF" />
          <rect y="45"   width="300" height="15" fill="#FFFFFF" />
          <rect y="75"   width="300" height="15" fill="#FFFFFF" />
          <rect width="120" height="107" fill="#3C3B6E" />
        </svg>
      </div>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col items-center min-h-screen px-4 py-12 max-w-5xl mx-auto">
      
      <!-- Title Area -->
      <div class="text-center mb-16 w-full relative z-20">
        <div class="lang-en-content animate-fade-in">
          <h1 class="font-serif text-5xl md:text-7xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">Full Gallery</h1>
          <p class="text-xl text-gray-400 mt-4 font-medium tracking-widest uppercase">Every place. Every memory.</p>
        </div>

        <div class="lang-th-content animate-fade-in">
          <h1 class="font-serif text-5xl md:text-7xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">แกลเลอรี่ทั้งหมด</h1>
        </div>

        <div class="lang-ch-content animate-fade-in">
          <h1 class="font-serif text-5xl md:text-7xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">完整图库</h1>
        </div>
      </div>

      <!-- Countries Sections -->
      <div class="flex flex-col gap-16 w-full relative z-20">
        {sections.map(section => (
          <div class="w-full">
            <h2 class="font-serif text-2xl md:text-3xl font-bold text-[#C5A059] mb-8 border-b border-[#C5A059]/20 pb-4 flex items-center gap-4">
              <span class="opacity-80">{section.country}</span>
              <div class="h-[1px] flex-grow bg-gradient-to-r from-[#C5A059]/20 to-transparent"></div>
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
              {section.cities.map(city => (
                <a
                  href={city.href}
                  class="group flex flex-col items-center gap-4 p-6 rounded-sm bg-[#1a1a1a]/70 backdrop-blur-md border border-[#C5A059]/20 hover:border-[#C5A059]/60 shadow-2xl transition-all duration-300 hover:-translate-y-1"
                >
                  <!-- Folder Icon -->
                  <svg class="w-20 h-16 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 96 78" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="16" width="92" height="60" rx="4" fill="#1a1a1a" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.3"/>
                    <path d="M2 16 L2 9 Q2 7 5 7 L32 7 Q35 7 37 9 L43 16 Z" fill="#1a1a1a" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.3"/>
                    <rect x="2" y="24" width="92" height="52" rx="4" fill="#121212" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
                    <line x1="14" y1="38" x2="82" y2="38" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
                    <line x1="14" y1="50" x2="82" y2="50" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
                    <line x1="14" y1="62" x2="82" y2="62" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
                  </svg>
                  
                  <div class="text-center">
                    <p class="font-serif text-lg text-gray-200 group-hover:text-[#C5A059] transition-colors leading-tight">{city.name}</p>
                    <p class="text-[10px] text-[#C5A059]/60 tracking-widest uppercase mt-1 opacity-70">{city.sub}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>

</MainLayout>

<!-- Global Styles -->
<style is:global>
  body, html {
    background-color: #121212 !important;
    color: #d1d5db;
    margin: 0;
    padding: 0;
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
  
  .font-serif {
    font-family: 'Playfair Display', serif;
  }
</style>

<!-- Scoped Layout & Animation Styles -->
<style>
  /* Robust CSS to handle language visibility mapping to your MainLayout toggles */
  .lang-en-content,
  .lang-th-content,
  .lang-ch-content {
    display: none;
  }

  /* Show text depending on which radio button is active */
  #lang-en:checked ~ .content-wrapper .lang-en-content,
  #lang-th:checked ~ .content-wrapper .lang-th-content,
  #lang-ch:checked ~ .content-wrapper .lang-ch-content {
    display: block;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
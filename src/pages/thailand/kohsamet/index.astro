---
import MainLayout from '../../../layouts/MainLayout.astro';

const menuItems = [
  { label: 'Bangkok',    href: '/thailand/bangkok'    },
  { label: 'Nonthaburi', href: '/thailand/nonthaburi' },
  { separator: true },
  { label: 'Gallery',    href: '/thailand/kohsamet/gallery' },
];

const breadcrumbs = [
  { label: 'Home',     href: '/'         },
  { label: 'Thailand', href: '/thailand' },
];
---
<MainLayout title="Koh Samet | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>
  <!-- Triggers for Peer Logic -->
  <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

  <div slot="watermark" class="absolute inset-0 z-0 opacity-15 grayscale blur-[60px] pointer-events-none mix-blend-multiply transform scale-110">
    <svg width="100%" height="100%" preserveAspectRatio="none">
      <rect width="100%" height="16.66%" fill="#A51931" />
      <rect y="16.66%" width="100%" height="16.66%" fill="#F4F5F8" />
      <rect y="33.33%" width="100%" height="33.33%" fill="#2D2A4A" />
      <rect y="66.66%" width="100%" height="16.66%" fill="#F4F5F8" />
      <rect y="83.33%" width="100%" height="16.66%" fill="#A51931" />
    </svg>
  </div>

  <!-- EN -->
  <div class="hidden peer-checked/en:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">Koh Samet</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">Crystal waters and white sands on the closest island escape from the capital.</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[Enter text here]</p>
      <p class="text-lg leading-relaxed">[Enter text here]</p>
    </div>
    <a href="/thailand/kohsamet/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 View Gallery
    </a>
  </div>

  <!-- TH -->
  <div class="hidden peer-checked/th:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">เกาะเสม็ด</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">น้ำใสทรายขาวบนเกาะสวรรค์ที่ใกล้กรุงเทพฯ ที่สุด</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[กรอกข้อความที่นี่]</p>
      <p class="text-lg leading-relaxed">[กรอกข้อความที่นี่]</p>
    </div>
    <a href="/thailand/kohsamet/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 ดูแกลเลอรี่
    </a>
  </div>

  <!-- CH -->
  <div class="hidden peer-checked/ch:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">沙美岛</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">清澈的海水和白色的沙滩，离首都最近的岛屿避世之所。</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[在此输入文字]</p>
      <p class="text-lg leading-relaxed">[在此输入文字]</p>
    </div>
    <a href="/thailand/kohsamet/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 查看图库
    </a>
  </div>

</MainLayout>

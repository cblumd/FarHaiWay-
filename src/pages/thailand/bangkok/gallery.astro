---
import MainLayout from '../../../layouts/MainLayout.astro';
// Using the corrected import path targeting the assets folder
import bgImage from '../../../assets/Thailand_at_night.jpg';

const menuItems = [
  { label: 'Nonthaburi', href: '/thailand/nonthaburi' },
  { label: 'Koh Samet',  href: '/thailand/kohsamet'   },
  { separator: true },
  { label: '← Back to Bangkok', href: '/thailand/bangkok' },
];

const breadcrumbs = [
  { label: 'Home',     href: '/'                 },
  { label: 'Thailand', href: '/thailand'         },
  { label: 'Bangkok',  href: '/thailand/bangkok' },
];
---

<MainLayout title="Gallery — Bangkok | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <style is:global>
    body, html {
      background-color: #121212 !important;
      color: #d1d5db;
      margin: 0;
      padding: 0;
    }
    /* Import Playfair Display for consistency */
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
    
    .font-serif {
      font-family: 'Playfair Display', serif;
    }
  </style>

  <!-- Background: Local Nighttime Satellite Image -->
  <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
    <img 
      src={bgImage.src} 
      alt="Nighttime satellite view of Thailand" 
      class="w-full h-full object-cover opacity-50 mix-blend-screen"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
  </div>

  <!-- Main Content Container -->
  <div class="relative z-10 flex flex-col justify-center items-center min-h-[85vh] px-4 py-12 max-w-4xl mx-auto gap-12">

    <!-- Triggers for Peer Logic -->
    <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
    <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
    <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

    <!-- EN CONTENT -->
    <div class="hidden peer-checked/en:flex flex-col items-center w-full animate-fade-in">
      <h1 class="font-serif text-4xl md:text-6xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)] text-center">Gallery for Bangkok</h1>
    </div>

    <!-- TH CONTENT -->
    <div class="hidden peer-checked/th:flex flex-col items-center w-full animate-fade-in">
      <h1 class="font-serif text-4xl md:text-6xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)] text-center">แกลเลอรี่สำหรับกรุงเทพฯ</h1>
    </div>

    <!-- CH CONTENT -->
    <div class="hidden peer-checked/ch:flex flex-col items-center w-full animate-fade-in">
      <h1 class="font-serif text-4xl md:text-6xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)] text-center">曼谷图库</h1>
    </div>

    <!-- Link Section (Styling matched to Nonthaburi Gallery) -->
    <div class="mt-8 bg-[#1a1a1a]/40 px-8 py-8 rounded-sm backdrop-blur-md border border-[#C5A059]/20 text-gray-300 shadow-2xl w-full max-w-md mx-auto flex flex-col items-center z-10 animate-fade-in">
      <p class="text-lg mb-4">Google Drive Link:</p>
      
      <a 
        href="https://drive.google.com/drive/folders/1Bi7eKCws7x9ZbJ24VGyjPuYbSpT9bNtS?usp=drive_link" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="bg-[#C5A059] hover:bg-[#b5904d] text-[#121212] font-bold text-xl py-3 px-12 rounded-md transition-transform hover:scale-105 shadow-[0_4px_14px_rgba(0,0,0,0.5)]"
      >
        Click Here
      </a>
      
      <p class="text-sm opacity-60 mt-5 italic text-center">Media will open in a view-only Drive folder.</p>
    </div>

  </div>

</MainLayout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
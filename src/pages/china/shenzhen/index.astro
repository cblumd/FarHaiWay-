---
import MainLayout from '../../../layouts/MainLayout.astro';

const menuItems = [
  { label: 'Zhuhai',    href: '/china/zhuhai'    },
  { label: 'Guangzhou', href: '/china/guangzhou' },
  { label: 'Hong Kong', href: '/china/hongkong'  },
  { label: 'Macau',     href: '/china/macau'     },
  { separator: true },
  { label: 'Gallery',   href: '/china/shenzhen/gallery' },
];

const breadcrumbs = [
  { label: 'Home',  href: '/'      },
  { label: 'China', href: '/china' },
];
---
<MainLayout title="Shenzhen | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <div slot="watermark" class="absolute top-10 left-10 opacity-15 pointer-events-none transform scale-150 origin-top-left z-0">
    <svg width="200" height="150" viewBox="0 0 300 200" fill="#F4E4BC">
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(1.5) translate(10,15)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,20) rotate(20)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,70) rotate(40)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,140) rotate(0)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,190) rotate(-20)" />
    </svg>
  </div>

  <!-- EN -->
  <div class="flex flex-col items-center peer-checked/th:hidden peer-checked/ch:hidden">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">Shenzhen</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">The Silicon Valley of China</p>
    <h1 class="text-5xl font-bold text-[#F4E4BC] drop-shadow-md mt-8">Shenzhen</h1>
    <p class="text-xl text-[#E0F7FA] mt-2 font-medium">my adventures in Shenzhen</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[Enter text here]</p>
      <p class="text-lg leading-relaxed">[Enter text here]</p>
    </div>
    <a href="/china/shenzhen/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 View Gallery
    </a>
  </div>

  <!-- TH -->
  <div class="hidden peer-checked/th:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">เซินเจิ้น</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">ซิลิคอนวัลเลย์แห่งจีน</p>
    <h1 class="text-5xl font-bold text-[#F4E4BC] drop-shadow-md mt-8">เซินเจิ้น</h1>
    <p class="text-xl text-[#E0F7FA] mt-2 font-medium">การผจญภัยของฉันในเซินเจิ้น</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[กรอกข้อความที่นี่]</p>
      <p class="text-lg leading-relaxed">[กรอกข้อความที่นี่]</p>
    </div>
    <a href="/china/shenzhen/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 ดูแกลเลอรี่
    </a>
  </div>

  <!-- CH -->
  <div class="hidden peer-checked/ch:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">深圳</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">中国的硅谷</p>
    <h1 class="text-5xl font-bold text-[#F4E4BC] drop-shadow-md mt-8">深圳</h1>
    <p class="text-xl text-[#E0F7FA] mt-2 font-medium">我在深圳的冒险</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[在此输入文字]</p>
      <p class="text-lg leading-relaxed">[在此输入文字]</p>
    </div>
    <a href="/china/shenzhen/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 查看图库
    </a>
  </div>

</MainLayout>

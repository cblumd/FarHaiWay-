---
import MainLayout from '../layouts/MainLayout.astro';

const menuItems = [
  { label: 'China',    href: '/china'    },
  { label: 'Thailand', href: '/thailand' },
  { label: 'USA',      href: '/usa'      },
  { separator: true },
  { label: 'Full Gallery', href: '/gallery' },
];
---
<MainLayout title="FarHaiWay" menuItems={menuItems}>
  <!-- Triggers for Peer Logic -->
  <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

  <!-- Watermark: all three country flags distributed horizontally -->
  <div slot="watermark" class="absolute inset-0 z-0 pointer-events-none flex items-start justify-between px-16 pt-10">

    <!-- China — 5-star constellation -->
    <div class="opacity-15 transform scale-125 origin-top-left">
      <svg width="160" height="120" viewBox="0 0 300 200" fill="#F4E4BC">
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(1.5) translate(10,15)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,20) rotate(20)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,70) rotate(40)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,140) rotate(0)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,190) rotate(-20)" />
      </svg>
    </div>

    <!-- Thailand — tricolor stripes (centered) -->
    <div class="opacity-15 blur-[1px] transform scale-125 origin-top">
      <svg width="160" height="120" viewBox="0 0 300 200" preserveAspectRatio="none">
        <rect width="300" height="33"  fill="#A51931" />
        <rect y="33"  width="300" height="33" fill="#F4F5F8" />
        <rect y="66"  width="300" height="68" fill="#2D2A4A" />
        <rect y="134" width="300" height="33" fill="#F4F5F8" />
        <rect y="167" width="300" height="33" fill="#A51931" />
      </svg>
    </div>

    <!-- USA — stripes + canton -->
    <div class="opacity-15 blur-[1px] transform scale-125 origin-top-right">
      <svg width="160" height="120" viewBox="0 0 300 200" preserveAspectRatio="none">
        <rect width="300" height="200" fill="#B22234" />
        <rect y="15"   width="300" height="15" fill="#FFFFFF" />
        <rect y="45"   width="300" height="15" fill="#FFFFFF" />
        <rect y="75"   width="300" height="15" fill="#FFFFFF" />
        <rect y="105"  width="300" height="15" fill="#FFFFFF" />
        <rect y="135"  width="300" height="15" fill="#FFFFFF" />
        <rect y="165"  width="300" height="15" fill="#FFFFFF" />
        <rect width="120" height="107" fill="#3C3B6E" />
      </svg>
    </div>

  </div>

  <!-- Hero content -->
  <div class="hidden peer-checked/en:block">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">FarHaiWay</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">Check out my adventures</p>
  </div>

  <div class="hidden peer-checked/th:block">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">FarHaiWay</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">ตรวจสอบการผจญภัยของฉัน</p>
  </div>

  <div class="hidden peer-checked/ch:block">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">远海之路</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">看看我的冒险</p>
  </div>

</MainLayout>

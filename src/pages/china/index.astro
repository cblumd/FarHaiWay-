---
import MainLayout from '../../layouts/MainLayout.astro';

const menuItems = [
 { label: 'Zhuhai', href: '/china/zhuhai' },
 { label: 'Guangzhou', href: '/china/guangzhou' },
 { label: 'Shenzhen', href: '/china/shenzhen' },
 { label: 'Hong Kong', href: '/china/hongkong' },
 { label: 'Macau', href: '/china/macau' },
 { separator: true },
 { label: 'Full Gallery', href: '/china/gallery' },
];

const breadcrumbs = [
 { label: 'Home', href: '/' },
];

// รายการเมืองสำหรับการสร้างปุ่มใน Grid
const cities = [
 { label: 'Zhuhai', href: '/china/zhuhai' },
 { label: 'Guangzhou', href: '/china/guangzhou' },
 { label: 'Shenzhen', href: '/china/shenzhen' },
 { label: 'Hong Kong', href: '/china/hongkong' },
 { label: 'Macau', href: '/china/macau' },
 { label: 'Full Gallery', href: '/china/gallery' },
];
---

<MainLayout title="China Adventures | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

 <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
 <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
 <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

 <style is:global>
 body, html {
 background-color: #121212 !important;
 color: #d1d5db;
 margin: 0;
 padding: 0;
 }
 /* Import Playfair Display */
 @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
 
 .font-serif {
 font-family: 'Playfair Display', serif;
 }
 </style>

 <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
 <img 
 src="https://images.unsplash.com/photo-1544819667-97505127bb5a?q=80&w=2000&auto=format&fit=crop" 
 alt="China at night from space" 
 class="w-full h-full object-cover opacity-50 mix-blend-screen"
 />
 <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
 </div>

 <div class="relative z-10 flex flex-col items-center min-h-screen px-4 py-12 max-w-4xl mx-auto">
 
 <div class="text-center mb-10">
 <div class="hidden peer-checked/en:block animate-fade-in">
 <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">China</h1>
 <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">Check out my adventures</p>
 </div>

 <div class="hidden peer-checked/th:block animate-fade-in">
 <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">ประเทศจีน</h1>
 <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-wide">การผจญภัยของฉันในประเทศจีน</p>
 </div>

 <div class="hidden peer-checked/ch:block animate-fade-in">
 <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">中国</h1>
 <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest">我在中国的冒险</p>
 </div>
 </div>

 <div class="w-full mb-12 bg-[#1a1a1a]/70 backdrop-blur-md border border-[#C5A059]/20 p-8 rounded-sm shadow-2xl">
 <div class="hidden peer-checked/en:block animate-fade-in text-gray-300">
 <p class="text-lg leading-relaxed mb-4 italic">I am currently based in the coastal city of Zhuhai, working as a high school teacher. I spend my days teaching math, basic science, and economics to 10th and 11th-grade ESL students.</p>
 <p class="text-lg leading-relaxed">Living here provides the perfect launchpad for my travels, allowing me to frequently hop over and explore incredible nearby cities and regions.</p>
 </div>

 <div class="hidden peer-checked/th:block animate-fade-in text-gray-300">
 <p class="text-lg leading-relaxed mb-4 italic">ปัจจุบันฉันพำนักอยู่ในเมืองชายฝั่งทะเลจูไห่ ทำงานเป็นครูโรงเรียนมัธยมปลาย ฉันสอนวิชาคณิตศาสตร์ วิทยาศาสตร์พื้นฐาน และเศรษฐศาสตร์ให้กับนักเรียน ESL</p>
 <p class="text-lg leading-relaxed">การอาศัยอยู่ที่นี่เป็นจุดเริ่มต้นที่สมบูรณ์แบบสำหรับการเดินทาง ช่วยให้ฉันสามารถไปสำรวจเมืองและภูมิภาคใกล้เคียงที่น่าทึ่งได้อย่างบ่อยครั้ง</p>
 </div>

 <div class="hidden peer-checked/ch:block animate-fade-in text-gray-300">
 <p class="text-lg leading-relaxed mb-4 italic">我目前居住在海滨城市珠海，担任高中教师。我向 ESL 学生教授数学、基础科学和经济学。</p>
 <p class="text-lg leading-relaxed">住在这里为我的旅行提供了完美的出发点，让我能够频繁地前往并探索周边令人惊叹的城市和地区。</p>
 </div>
 </div>

 <div class="w-full grid grid-cols-2 md:grid-cols-3 gap-4">
 {cities.map((city) => (
 <a href={city.href} class="group relative py-4 px-2 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg">
 <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider">
 {city.label}
 </span>
 <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
 </a>
 ))}
 </div>

 </div>

</MainLayout>

<style>
 .animate-fade-in {
 animation: fadeIn 0.8s ease-out forwards;
 }

 @keyframes fadeIn {
 from { opacity: 0; transform: translateY(15px); }
 to { opacity: 1; transform: translateY(0); }
 }
</style>
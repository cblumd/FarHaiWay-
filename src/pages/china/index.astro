---
import MainLayout from '../../layouts/MainLayout.astro';

const menuItems = [
  { label: 'Zhuhai',    href: '/china/zhuhai'    },
  { label: 'Guangzhou', href: '/china/guangzhou' },
  { label: 'Shenzhen',  href: '/china/shenzhen'  },
  { label: 'Hong Kong', href: '/china/hongkong'  },
  { label: 'Macau',     href: '/china/macau'     },
  { separator: true },
  { label: 'Full Gallery', href: '/china/gallery' },
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
];
---
<MainLayout title="China Adventures | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Triggers for Peer Logic -->
  <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

  <!-- Watermark: 5-star constellation -->
  <div slot="watermark" class="absolute top-10 left-10 opacity-15 pointer-events-none transform scale-150 origin-top-left z-0">
    <svg width="200" height="150" viewBox="0 0 300 200" fill="#F4E4BC">
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(1.5) translate(10,15)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,20) rotate(20)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,70) rotate(40)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,140) rotate(0)" />
      <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,190) rotate(-20)" />
    </svg>
  </div>

  <!-- EN -->
  <div class="hidden peer-checked/en:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">China</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">Check out my adventures in China</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">I am currently based in the coastal city of Zhuhai, working as a high school teacher. I spend my days teaching math, basic science, and economics to 10th and 11th-grade ESL students.</p>
      <p class="text-lg leading-relaxed">Living here provides the perfect launchpad for my travels, allowing me to frequently hop over and explore incredible nearby cities and regions.</p>
    </div>
  </div>

  <!-- TH -->
  <div class="hidden peer-checked/th:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">ประเทศจีน</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">การผจญภัยของฉันในประเทศจีน</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">ปัจจุบันฉันพำนักอยู่ในเมืองชายฝั่งทะเลจูไห่ ทำงานเป็นครูโรงเรียนมัธยมปลาย ฉันสอนวิชาคณิตศาสตร์ วิทยาศาสตร์พื้นฐาน และเศรษฐศาสตร์ให้กับนักเรียน ESL</p>
      <p class="text-lg leading-relaxed">การอาศัยอยู่ที่นี่เป็นจุดเริ่มต้นที่สมบูรณ์แบบสำหรับการเดินทาง ช่วยให้ฉันสามารถไปสำรวจเมืองและภูมิภาคใกล้เคียงที่น่าทึ่งได้อย่างบ่อยครั้ง</p>
    </div>
  </div>

  <!-- CH -->
  <div class="hidden peer-checked/ch:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">中国</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">我在中国的冒险</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">我目前居住在海滨城市珠海，担任高中教师。我向 ESL 学生教授数学、基础科学和经济学。</p>
      <p class="text-lg leading-relaxed">住在这里为我的旅行提供了完美的出发点，让我能够频繁地前往并探索周边令人惊叹的城市和地区。</p>
    </div>
  </div>

</MainLayout>

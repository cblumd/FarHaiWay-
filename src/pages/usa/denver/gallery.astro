---
import MainLayout from '../../../layouts/MainLayout.astro';
// Importing the local USA night map asset
import usaNightMap from '../../../assets/USA_NIGHT.jpg';

const menuItems = [
  { label: 'Broomfield', href: '/usa/broomfield' },
  { label: 'Boulder',    href: '/usa/boulder'    },
  { separator: true },
  { label: '← Back to Denver', href: '/usa/denver' },
];

const breadcrumbs = [
  { label: 'Home',   href: '/'            },
  { label: 'USA',    href: '/usa'         },
  { label: 'Denver', href: '/usa/denver'  },
];
---

<MainLayout title="Gallery — Denver | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Language Radio Inputs (Kept at top level for CSS targeting) -->
  <input type="radio" name="lang-peer" id="lang-en" class="hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="hidden" />

  <div class="content-wrapper">
    <!-- Background Image Section -->
    <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
      <img 
        src={usaNightMap.src || usaNightMap} 
        alt="Nighttime view of USA" 
        class="w-full h-full object-cover opacity-50 mix-blend-screen"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
    </div>

    <!-- Optional Watermark: US flag style -->
    <div slot="watermark" class="absolute inset-0 z-0 opacity-5 blur-2xl pointer-events-none mix-blend-overlay transform scale-110">
      <svg width="100%" height="100%" preserveAspectRatio="none">
        <rect width="100%" height="100%" fill="#B22234" />
        <rect y="7.69%"  width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="23.07%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="38.46%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="53.84%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="69.23%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="84.61%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect width="40%" height="53.84%" fill="#3C3B6E" />
      </svg>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-[80vh] px-4 py-12 max-w-4xl mx-auto">
      
      <div class="flex flex-col items-center gap-6 w-full relative z-20">
        
        <!-- Folder Icon Link -->
        <a href="https://drive.google.com/drive/folders/1b-_Fjlee5Q2y9iXBcW3hyy3KUZXi-fNk?usp=drive_link" target="_blank" rel="noopener noreferrer" class="group hover:scale-105 transition-transform duration-300">
          <svg width="280" height="220" viewBox="0 0 96 78" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="16" width="92" height="60" rx="4" fill="#1a1a1a" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.3"/>
            <path d="M2 16 L2 9 Q2 7 5 7 L32 7 Q35 7 37 9 L43 16 Z" fill="#1a1a1a" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.3"/>
            <rect x="2" y="24" width="92" height="52" rx="4" fill="#121212" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
            <line x1="14" y1="38" x2="82" y2="38" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
            <line x1="14" y1="50" x2="82" y2="50" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
            <line x1="14" y1="62" x2="82" y2="62" stroke="#C5A059" stroke-width="1.5" stroke-opacity="0.6"/>
          </svg>
        </a>

        <!-- EN -->
        <div class="lang-en-content animate-fade-in text-center w-full">
          <h1 class="font-serif text-5xl md:text-6xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">Gallery for Denver</h1>
          <div class="mt-8 bg-[#1a1a1a]/70 px-8 py-8 rounded-sm backdrop-blur-md border border-[#C5A059]/20 text-gray-300 shadow-2xl max-w-md mx-auto flex flex-col items-center">
            <p class="text-lg mb-4">Google Drive Link:</p>
            <a href="https://drive.google.com/drive/folders/1b-_Fjlee5Q2y9iXBcW3hyy3KUZXi-fNk?usp=drive_link" target="_blank" rel="noopener noreferrer" class="bg-[#C5A059] text-[#121212] font-bold py-3 px-8 rounded hover:bg-white transition-colors duration-300 shadow-lg">
              Click Here
            </a>
            <p class="text-sm opacity-60 mt-5 italic">Media will open in a view-only Drive folder.</p>
          </div>
        </div>

        <!-- TH -->
        <div class="lang-th-content animate-fade-in text-center w-full">
          <h1 class="font-serif text-5xl md:text-6xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">แกลเลอรี่สำหรับเดนเวอร์</h1>
          <div class="mt-8 bg-[#1a1a1a]/70 px-8 py-8 rounded-sm backdrop-blur-md border border-[#C5A059]/20 text-gray-300 shadow-2xl max-w-md mx-auto flex flex-col items-center">
            <p class="text-lg mb-4">ลิงก์ Google Drive:</p>
            <a href="https://drive.google.com/drive/folders/1b-_Fjlee5Q2y9iXBcW3hyy3KUZXi-fNk?usp=drive_link" target="_blank" rel="noopener noreferrer" class="bg-[#C5A059] text-[#121212] font-bold py-3 px-8 rounded hover:bg-white transition-colors duration-300 shadow-lg">
              คลิกที่นี่
            </a>
            <p class="text-sm opacity-60 mt-5 italic">สื่อจะเปิดในโฟลเดอร์ Drive แบบดูได้อย่างเดียว</p>
          </div>
        </div>

        <!-- CH -->
        <div class="lang-ch-content animate-fade-in text-center w-full">
          <h1 class="font-serif text-5xl md:text-6xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">丹佛图库</h1>
          <div class="mt-8 bg-[#1a1a1a]/70 px-8 py-8 rounded-sm backdrop-blur-md border border-[#C5A059]/20 text-gray-300 shadow-2xl max-w-md mx-auto flex flex-col items-center">
            <p class="text-lg mb-4">Google Drive 链接:</p>
            <a href="https://drive.google.com/drive/folders/1b-_Fjlee5Q2y9iXBcW3hyy3KUZXi-fNk?usp=drive_link" target="_blank" rel="noopener noreferrer" class="bg-[#C5A059] text-[#121212] font-bold py-3 px-8 rounded hover:bg-white transition-colors duration-300 shadow-lg">
              点击这里
            </a>
            <p class="text-sm opacity-60 mt-5 italic">媒体将在仅供查看的云端硬盘文件夹中打开。</p>
          </div>
        </div>

      </div>

    </div>
  </div>

</MainLayout>

<style is:global>
  body, html {
    background-color: #121212 !important;
    color: #d1d5db;
    margin: 0;
    padding: 0;
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
  
  .font-serif {
    font-family: 'Playfair Display', serif;
  }
</style>

<style>
  /* Robust CSS to handle language visibility mapping to your MainLayout toggles */
  .lang-en-content,
  .lang-th-content,
  .lang-ch-content {
    display: none;
  }

  /* Show text depending on which radio button is active */
  #lang-en:checked ~ .content-wrapper .lang-en-content,
  #lang-th:checked ~ .content-wrapper .lang-th-content,
  #lang-ch:checked ~ .content-wrapper .lang-ch-content {
    display: block;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
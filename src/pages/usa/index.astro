---
import MainLayout from '../../layouts/MainLayout.astro';
import en from '../../i18n/en.json';
import th from '../../i18n/th.json';
import ch from '../../i18n/ch.json';

const menuItems = [
  { label: 'Broomfield', href: '/usa/broomfield' },
  { label: 'Boulder',    href: '/usa/boulder'    },
  { label: 'Denver',     href: '/usa/denver'     },
  { separator: true },
  { label: 'Full Gallery', href: '/usa/gallery' },
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
];
---
<MainLayout title="USA Adventures | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Triggers for Peer Logic -->
  <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

  <!-- Watermark: US flag stripes + canton -->
  <div slot="watermark" class="absolute inset-0 z-0 opacity-15 blur-2xl pointer-events-none mix-blend-multiply transform scale-110">
    <svg width="100%" height="100%" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="#B22234" />
      <rect y="7.69%"  width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="23.07%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="38.46%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="53.84%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="69.23%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="84.61%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect width="40%" height="53.84%" fill="#3C3B6E" />
    </svg>
  </div>

  <!-- EN -->
  <div class="hidden peer-checked/en:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">{en.usa_header}</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">{en.usa_adventures}</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">I am an American citizen born in Florida, but I was raised for most of my life in Colorado.</p>
      <p class="text-lg leading-relaxed">When I am stateside, I am primarily located in the Broomfield area, though I frequently travel to Denver and Boulder. It's the perfect home base between the city life and the beautiful Rocky Mountains.</p>
    </div>
    <div class="mt-8 w-full flex justify-center">
      <div class="flex gap-4 flex-wrap justify-center">
        <a href="/usa/boulder" aria-label={en.boulder_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{en.boulder_header}</a>
        <a href="/usa/broomfield" aria-label={en.broomfield_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{en.broomfield_header}</a>
        <a href="/usa/denver" aria-label={en.denver_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{en.denver_header}</a>
      </div>
    </div>
  </div>

  <!-- TH -->
  <div class="hidden peer-checked/th:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">{th.usa_header}</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">{th.usa_adventures}</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">ฉันเป็นพลเมืองอเมริกัน เกิดที่รัฐฟลอริดา แต่เติบโตและใช้ชีวิตส่วนใหญ่ในรัฐโคโลราโด</p>
      <p class="text-lg leading-relaxed">เมื่อฉันอยู่ที่อเมริกา ฉันมักจะพักอาศัยอยู่ในย่านบรุมฟิลด์ (Broomfield) เป็นหลัก แต่ก็เดินทางไปเดนเวอร์ (Denver) และโบลเดอร์ (Boulder) บ่อยครั้ง</p>
    </div>
    <div class="mt-8 w-full flex justify-center">
      <div class="flex gap-4 flex-wrap justify-center">
        <a href="/usa/boulder" aria-label={th.boulder_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{th.boulder_header}</a>
        <a href="/usa/broomfield" aria-label={th.broomfield_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{th.broomfield_header}</a>
        <a href="/usa/denver" aria-label={th.denver_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{th.denver_header}</a>
      </div>
    </div>
  </div>

  <!-- CH -->
  <div class="hidden peer-checked/ch:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">{ch.usa_header}</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">{ch.usa_adventures}</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">我是一名美国公民，出生在佛罗里达州，但我的大部分生活都是在科罗拉多州度过的。</p>
      <p class="text-lg leading-relaxed">当我在美国时，我主要在布鲁姆菲尔德（Broomfield）地区活动，但也经常前往丹佛（Denver）和博尔德（Boulder）。这里是连接城市生活和美丽的落基山脉的完美大本营。</p>
    </div>
    <div class="mt-8 w-full flex justify-center">
      <div class="flex gap-4 flex-wrap justify-center">
        <a href="/usa/boulder" aria-label={ch.boulder_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{ch.boulder_header}</a>
        <a href="/usa/broomfield" aria-label={ch.broomfield_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{ch.broomfield_header}</a>
        <a href="/usa/denver" aria-label={ch.denver_header} class="w-44 h-28 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold rounded-xl shadow transition-transform duration-150 hover:-translate-y-1">{ch.denver_header}</a>
      </div>
    </div>
  </div>

</MainLayout>

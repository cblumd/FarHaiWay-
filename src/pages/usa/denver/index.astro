---
import MainLayout from '../../../layouts/MainLayout.astro';
// Importing the local USA night map asset
import usaNightMap from '../../../assets/USA_NIGHT.jpg';
import en from '../../../i18n/en.json';
import th from '../../../i18n/th.json';
import ch from '../../../i18n/ch.json';

const menuItems = [
  { label: 'Broomfield', href: '/usa/broomfield' },
  { label: 'Boulder',    href: '/usa/boulder'    },
  { separator: true },
  { label: 'Gallery',    href: '/usa/denver/gallery' },
];

const breadcrumbs = [
  { label: 'Home', href: '/'    },
  { label: 'USA',  href: '/usa' },
];
---

<MainLayout title="Denver | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Language Radio Inputs -->
  <input type="radio" name="lang-peer" id="lang-en" class="hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="hidden" />

  <div class="content-wrapper">
    <!-- Background Image Section -->
    <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
      <img 
        src={usaNightMap.src || usaNightMap} 
        alt="Nighttime view of USA" 
        class="w-full h-full object-cover opacity-50 mix-blend-screen"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
    </div>

    <!-- Optional Watermark -->
    <div slot="watermark" class="absolute inset-0 z-0 opacity-5 blur-2xl pointer-events-none mix-blend-overlay transform scale-110">
      <svg width="100%" height="100%" preserveAspectRatio="none">
        <rect width="100%" height="100%" fill="#B22234" />
        <rect y="7.69%"  width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="23.07%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="38.46%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="53.84%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="69.23%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="84.61%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect width="40%" height="53.84%" fill="#3C3B6E" />
      </svg>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col items-center min-h-screen px-4 py-12 max-w-4xl mx-auto">
      
      <!-- Title Area -->
      <div class="text-center mb-10 w-full relative z-20">
        <div class="lang-en-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">{en.denver_header}</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">{en.denver_adventures}</p>
        </div>

        <div class="lang-th-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">{th.denver_header}</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-wide">{th.denver_adventures}</p>
        </div>

        <div class="lang-ch-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">{ch.denver_header}</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">{ch.denver_adventures}</p>
        </div>
      </div>

      <!-- Main Description Box -->
      <div class="w-full mb-12 bg-[#1a1a1a]/70 backdrop-blur-md border border-[#C5A059]/20 p-8 rounded-sm shadow-2xl relative z-20">
        <div class="lang-en-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">Denver, the Mile High City, is a bustling metropolis located at the foot of the Rocky Mountains. It's known for its world-class museums, professional sports teams, and a vibrant downtown area filled with history and modern culture.</p>
          <p class="text-lg leading-relaxed">Whether I'm catching a game or exploring the local art scene, Denver always offers an energetic urban contrast to the quiet suburbs and mountain trails nearby.</p>
        </div>

        <div class="lang-th-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">เดนเวอร์ หรือเมือง Mile High City เป็นมหานครที่คึกคักตั้งอยู่บริเวณเชิงเขาเทือกเขาร็อกกี้ ขึ้นชื่อเรื่องพิพิธภัณฑ์ระดับโลก ทีมกีฬามืออาชีพ และย่านใจกลางเมืองที่มีชีวิตชีวาซึ่งเต็มไปด้วยประวัติศาสตร์และวัฒนธรรมสมัยใหม่</p>
          <p class="text-lg leading-relaxed">ไม่ว่าฉันจะไปชมการแข่งขันกีฬาหรือสำรวจแกลเลอรี่งานศิลปะในท้องถิ่น เดนเวอร์ก็มักจะมอบบรรยากาศเมืองที่มีพลัง แตกต่างจากย่านชานเมืองที่เงียบสงบและเส้นทางเดินป่าที่อยู่ใกล้เคียงเสมอ</p>
        </div>

        <div class="lang-ch-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">丹佛，又被称为“一英里高城”，是坐落在落基山脚下的一座繁华大都市。它以世界级的博物馆、职业运动队以及充满历史和现代气息的活力市中心而闻名。</p>
          <p class="text-lg leading-relaxed">无论是去看一场球赛，还是探索当地的艺术场景，丹佛总是能为附近的安静郊区和山间小道提供充满活力的都市对比。</p>
        </div>
      </div>

      <!-- Gallery Button -->
      <div class="w-full flex justify-center relative z-20">
        <div class="lang-en-content w-full md:w-auto">
          <a href="/usa/denver/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 View Gallery
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>

        <div class="lang-th-content w-full md:w-auto">
          <a href="/usa/denver/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 ดูแกลเลอรี่
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>

        <div class="lang-ch-content w-full md:w-auto">
          <a href="/usa/denver/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 查看图库
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>
      </div>

    </div>
  </div>

</MainLayout>

<style is:global>
  body, html {
    background-color: #121212 !important;
    color: #d1d5db;
    margin: 0;
    padding: 0;
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
  
  .font-serif {
    font-family: 'Playfair Display', serif;
  }
</style>

<style>
  /* CSS-based language toggle visibility rules */
  .lang-en-content,
  .lang-th-content,
  .lang-ch-content {
    display: none;
  }

  #lang-en:checked ~ .content-wrapper .lang-en-content,
  #lang-th:checked ~ .content-wrapper .lang-th-content,
  #lang-ch:checked ~ .content-wrapper .lang-ch-content {
    display: block;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
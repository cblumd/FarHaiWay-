---
import MainLayout from '../../../layouts/MainLayout.astro';
// Importing the local background image from the src/assets folder
import chinaNightMap from '../../../assets/china_night_map.jpg';

const menuItems = [
  { label: 'Guangzhou', href: '/china/guangzhou' },
  { label: 'Shenzhen',  href: '/china/shenzhen'  },
  { label: 'Hong Kong', href: '/china/hongkong'  },
  { label: 'Macau',     href: '/china/macau'     },
  { separator: true },
  { label: 'Gallery',   href: '/china/zhuhai/gallery' },
];

const breadcrumbs = [
  { label: 'Home',  href: '/'      },
  { label: 'China', href: '/china' },
];
---

<MainLayout title="Zhuhai | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Language Radio Inputs (Kept at the top level for CSS targeting) -->
  <input type="radio" name="lang-peer" id="lang-en" class="hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="hidden" />

  <div class="content-wrapper">
    <!-- Background Image Section -->
    <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
      <img 
        src={chinaNightMap.src || chinaNightMap} 
        alt="Nighttime view of China from space" 
        class="w-full h-full object-cover opacity-50 mix-blend-screen"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
    </div>

    <!-- Watermark: 5-star constellation (Adapted to new theme colors) -->
    <div slot="watermark" class="absolute top-10 left-10 opacity-10 pointer-events-none transform scale-150 origin-top-left z-0">
      <svg width="200" height="150" viewBox="0 0 300 200" fill="#C5A059">
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(1.5) translate(10,15)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,20) rotate(20)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,70) rotate(40)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,140) rotate(0)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,190) rotate(-20)" />
      </svg>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col items-center min-h-screen px-4 py-12 max-w-4xl mx-auto">
      
      <!-- Title Area -->
      <div class="text-center mb-10 w-full relative z-20">
        <div class="lang-en-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">Zhuhai</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">Teaching and living in the City of Islands</p>
        </div>

        <div class="lang-th-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">จูไห่</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-wide">สอนหนังสือและใช้ชีวิตในเมืองแห่งเกาะต่างๆ</p>
        </div>

        <div class="lang-ch-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">珠海</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest">在百岛之市教学与生活</p>
        </div>
      </div>

      <!-- Text Box Description Area -->
      <div class="w-full mb-12 bg-[#1a1a1a]/70 backdrop-blur-md border border-[#C5A059]/20 p-8 rounded-sm shadow-2xl relative z-20">
        <div class="lang-en-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4">I have been living in Zhuhai since 2024. I love the hot seasons here; they match the coastal energy perfectly.</p>
          <p class="text-lg leading-relaxed">I'll admit I hate the cold season of Zhuhai, even though it's not actually that cold. Overall, it's a very chill city, but it has fun, bustling neighborhoods for when I want to get out and have a drink.</p>
        </div>

        <div class="lang-th-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4">ฉันอาศัยอยู่ในจูไห่มาตั้งแต่ปี 2024 ฉันชอบฤดูร้อนที่นี่มาก มันเข้ากับบรรยากาศเมืองชายฝั่งได้เป็นอย่างดี</p>
          <p class="text-lg leading-relaxed">ฉันสารภาพเลยว่าเกลียดฤดูหนาวของจูไห่ ถึงแม้ว่าจริงๆ แล้วมันจะไม่ได้หนาวขนาดนั้นก็ตาม โดยรวมแล้วที่นี่เป็นเมืองที่ชิลล์มาก แต่ก็มีย่านที่คึกคักและสนุกสนานสำหรับเวลาที่ฉันอยากออกไปดื่มสังสรรค์</p>
        </div>

        <div class="lang-ch-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4">我从2024年开始住在珠海。我非常喜欢这里的炎热季节，非常契合这座海滨城市的活力。</p>
          <p class="text-lg leading-relaxed">不得不承认，我很讨厌珠海的寒冷季节，尽管其实并没有那么冷。总的来说，这是一座非常悠闲的城市，但当我想要出去喝一杯时，这里也有非常繁华热闹的街区。</p>
        </div>
      </div>

      <!-- Gallery Button -->
      <div class="w-full flex justify-center relative z-20">
        <div class="lang-en-content w-full md:w-auto">
          <a href="/china/zhuhai/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 View Gallery
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>

        <div class="lang-th-content w-full md:w-auto">
          <a href="/china/zhuhai/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 ดูแกลเลอรี่
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>

        <div class="lang-ch-content w-full md:w-auto">
          <a href="/china/zhuhai/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 查看图库
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>
      </div>

    </div>
  </div>

</MainLayout>

<!-- Global Styles -->
<style is:global>
  body, html {
    background-color: #121212 !important;
    color: #d1d5db;
    margin: 0;
    padding: 0;
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
  
  .font-serif {
    font-family: 'Playfair Display', serif;
  }
</style>

<!-- Scoped Layout & Animation Styles -->
<style>
  /* Robust CSS to handle language visibility mapping to your MainLayout toggles */
  .lang-en-content,
  .lang-th-content,
  .lang-ch-content {
    display: none;
  }

  /* Show text depending on which radio button is active */
  #lang-en:checked ~ .content-wrapper .lang-en-content,
  #lang-th:checked ~ .content-wrapper .lang-th-content,
  #lang-ch:checked ~ .content-wrapper .lang-ch-content {
    display: block;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
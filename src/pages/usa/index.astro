---
import MainLayout from '../../layouts/MainLayout.astro';
// Importing the local USA night map asset
import usaNightMap from '../../assets/USA_NIGHT.jpg';

const menuItems = [
  { label: 'Broomfield', href: '/usa/broomfield' },
  { label: 'Boulder',    href: '/usa/boulder'    },
  { label: 'Denver',     href: '/usa/denver'     },
  { separator: true },
  { label: 'Full Gallery', href: '/usa/gallery' },
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
];

// Items for the interactive navigation grid
const locations = [
  { label: 'Broomfield', href: '/usa/broomfield' },
  { label: 'Boulder',    href: '/usa/boulder'    },
  { label: 'Denver',     href: '/usa/denver'     },
  { label: 'Full Gallery', href: '/usa/gallery' },
];
---

<MainLayout title="USA Adventures | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Language Radio Inputs -->
  <input type="radio" name="lang-peer" id="lang-en" class="hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="hidden" />

  <div class="content-wrapper">
    <!-- Background Image Section -->
    <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
      <img 
        src={usaNightMap.src || usaNightMap} 
        alt="Nighttime view of USA" 
        class="w-full h-full object-cover opacity-50 mix-blend-screen"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col items-center min-h-screen px-4 py-12 max-w-4xl mx-auto">
      
      <!-- Title Area -->
      <div class="text-center mb-10 w-full relative z-20">
        <div class="lang-en-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">USA</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">My adventures in the States</p>
        </div>

        <div class="lang-th-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">สหรัฐอเมริกา</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-wide">การผจญภัยของฉันในสหรัฐอเมริกา</p>
        </div>

        <div class="lang-ch-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">美国</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest">我在美国的冒险</p>
        </div>
      </div>

      <!-- Main Description Box -->
      <div class="w-full mb-12 bg-[#1a1a1a]/70 backdrop-blur-md border border-[#C5A059]/20 p-8 rounded-sm shadow-2xl relative z-20">
        <div class="lang-en-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">I am an American citizen born in Florida, but I was raised for most of my life in Colorado.</p>
          <p class="text-lg leading-relaxed">When I am stateside, I am primarily located in the Broomfield area, though I frequently travel to Denver and Boulder. It's the perfect home base between the city life and the beautiful Rocky Mountains.</p>
        </div>

        <div class="lang-th-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">ฉันเป็นพลเมืองอเมริกัน เกิดที่รัฐฟลอริดา แต่เติบโตและใช้ชีวิตส่วนใหญ่ในรัฐโคโลราโด</p>
          <p class="text-lg leading-relaxed">เมื่อฉันอยู่ที่อเมริกา ฉันมักจะพักอาศัยอยู่ในย่านบรุมฟิลด์ (Broomfield) เป็นหลัก แต่ก็เดินทางไปเดนเวอร์ (Denver) และโบลเดอร์ (Boulder) บ่อยครั้ง เป็นจุดเริ่มต้นที่สมบูรณ์แบบระหว่างชีวิตในเมืองและเทือกเขาร็อกกี้ที่สวยงาม</p>
        </div>

        <div class="lang-ch-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">我是一名美国公民，出生在佛罗里达州，但我的大部分生活都是在科罗拉多州度过的。</p>
          <p class="text-lg leading-relaxed">当我在美国时，我主要在布鲁姆菲尔德（Broomfield）地区活动，但也经常前往丹佛（Denver）和博尔德（Boulder）。这里是连接城市生活和美丽的落基山脉的完美大本营。</p>
        </div>
      </div>

      <!-- Navigation Grid -->
      <div class="w-full grid grid-cols-2 gap-4 relative z-20">
        {locations.map((item) => (
          <a href={item.href} class="group relative py-4 px-2 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider">
              {item.label}
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        ))}
      </div>

    </div>
  </div>

</MainLayout>

<style is:global>
  body, html {
    background-color: #121212 !important;
    color: #d1d5db;
    margin: 0;
    padding: 0;
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
  
  .font-serif {
    font-family: 'Playfair Display', serif;
  }
</style>

<style>
  /* CSS-based language toggle visibility rules */
  .lang-en-content,
  .lang-th-content,
  .lang-ch-content {
    display: none;
  }

  #lang-en:checked ~ .content-wrapper .lang-en-content,
  #lang-th:checked ~ .content-wrapper .lang-th-content,
  #lang-ch:checked ~ .content-wrapper .lang-ch-content {
    display: block;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
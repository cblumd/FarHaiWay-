---
import MainLayout from '../../../layouts/MainLayout.astro';
// Importing the same local USA night map asset
import usaNightMap from '../../../assets/USA_NIGHT.jpg';
import en from '../../../i18n/en.json';
import th from '../../../i18n/th.json';
import ch from '../../../i18n/ch.json';

const menuItems = [
  { label: 'Boulder', href: '/usa/boulder' },
  { label: 'Denver',  href: '/usa/denver'  },
  { separator: true },
  { label: 'Gallery', href: '/usa/broomfield/gallery' },
];

const breadcrumbs = [
  { label: 'Home', href: '/'    },
  { label: 'USA',  href: '/usa' },
];
---

<MainLayout title="Broomfield | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Language Radio Inputs -->
  <input type="radio" name="lang-peer" id="lang-en" class="hidden" checked />
  <input type="radio" name="lang-peer" id="lang-th" class="hidden" />
  <input type="radio" name="lang-peer" id="lang-ch" class="hidden" />

  <div class="content-wrapper">
    <!-- Background Image Section -->
    <div class="fixed inset-0 z-[-1] bg-[#121212] overflow-hidden pointer-events-none">
      <img 
        src={usaNightMap.src || usaNightMap} 
        alt="Nighttime view of USA" 
        class="w-full h-full object-cover opacity-50 mix-blend-screen"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/90 via-[#121212]/30 to-[#121212]/95"></div>
    </div>

    <!-- Optional Watermark: Kept from original but styled for new theme -->
    <div slot="watermark" class="absolute inset-0 z-0 opacity-5 blur-2xl pointer-events-none mix-blend-overlay transform scale-110">
      <svg width="100%" height="100%" preserveAspectRatio="none">
        <rect width="100%" height="100%" fill="#B22234" />
        <rect y="7.69%"  width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="23.07%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="38.46%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="53.84%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="69.23%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect y="84.61%" width="100%" height="7.69%" fill="#FFFFFF" />
        <rect width="40%" height="53.84%" fill="#3C3B6E" />
      </svg>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col items-center min-h-screen px-4 py-12 max-w-4xl mx-auto">
      
      <!-- Title Area -->
      <div class="text-center mb-10 w-full relative z-20">
        <div class="lang-en-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">{en.broomfield_header}</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">{en.broomfield_adventures}</p>
        </div>

        <div class="lang-th-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">{th.broomfield_header}</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-wide">{th.broomfield_adventures}</p>
        </div>

        <div class="lang-ch-content animate-fade-in">
          <h1 class="font-serif text-6xl md:text-8xl font-bold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)]">{ch.broomfield_header}</h1>
          <p class="text-xl md:text-2xl text-gray-400 mt-4 font-medium tracking-widest uppercase">{ch.broomfield_adventures}</p>
        </div>
      </div>

      <!-- Main Description Box -->
      <div class="w-full mb-12 bg-[#1a1a1a]/70 backdrop-blur-md border border-[#C5A059]/20 p-8 rounded-sm shadow-2xl relative z-20">
        <div class="lang-en-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">I have lived in Broomfield for a significant portion of my life. It is a quiet, comfortable suburb located right between the state's major city and its most scenic mountain escapes.</p>
          <p class="text-lg leading-relaxed">It's where I return to recharge and catch up with family and friends before my next adventure.</p>
        </div>

        <div class="lang-th-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">ฉันอาศัยอยู่ในบรุมฟิลด์มาเป็นเวลานาน เป็นย่านชานเมืองที่เงียบสงบและสะดวกสบาย ตั้งอยู่ระหว่างเมืองใหญ่และแหล่งท่องเที่ยวทางธรรมชาติบนภูเขาที่สวยงามที่สุดของรัฐ</p>
          <p class="text-lg leading-relaxed">ที่นี่คือที่ที่ฉันกลับมาเพื่อพักผ่อนและพบปะครอบครัวและเพื่อนฝูงก่อนจะเริ่มการผจญภัยครั้งต่อไป</p>
        </div>

        <div class="lang-ch-content animate-fade-in text-gray-300">
          <p class="text-lg leading-relaxed mb-4 italic">我生命中的大部分时间都住在布鲁姆菲尔德。这是一个安静、舒适的郊区，位于该州主要城市和风景最优美的山区度假胜地之间。</p>
          <p class="text-lg leading-relaxed">这是我在下一次冒险前充电以及与家人朋友叙旧的地方。</p>
        </div>
      </div>

      <!-- Gallery Button -->
      <div class="w-full flex justify-center relative z-20">
        <div class="lang-en-content w-full md:w-auto">
          <a href="/usa/broomfield/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 View Gallery
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>

        <div class="lang-th-content w-full md:w-auto">
          <a href="/usa/broomfield/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 ดูแกลเลอรี่
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>

        <div class="lang-ch-content w-full md:w-auto">
          <a href="/usa/broomfield/gallery" class="group relative py-4 px-8 text-center bg-[#121212]/50 backdrop-blur-sm border border-[#C5A059]/10 hover:border-[#C5A059]/60 transition-all duration-300 shadow-lg block">
            <span class="font-serif text-lg text-gray-300 group-hover:text-[#C5A059] transition-colors tracking-wider block">
              📁 查看图库
            </span>
            <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#800000] group-hover:w-full transition-all duration-500"></div>
          </a>
        </div>
      </div>

    </div>
  </div>

</MainLayout>

<style is:global>
  body, html {
    background-color: #121212 !important;
    color: #d1d5db;
    margin: 0;
    padding: 0;
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');
  
  .font-serif {
    font-family: 'Playfair Display', serif;
  }
</style>

<style>
  /* CSS-based language toggle visibility rules */
  .lang-en-content,
  .lang-th-content,
  .lang-ch-content {
    display: none;
  }

  #lang-en:checked ~ .content-wrapper .lang-en-content,
  #lang-th:checked ~ .content-wrapper .lang-th-content,
  #lang-ch:checked ~ .content-wrapper .lang-ch-content {
    display: block;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
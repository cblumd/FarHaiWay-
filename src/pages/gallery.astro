---
import MainLayout from '../layouts/MainLayout.astro';

const menuItems = [
  { label: 'China',    href: '/china'    },
  { label: 'Thailand', href: '/thailand' },
  { label: 'USA',      href: '/usa'      },
  { separator: true },
  { label: '← Home', href: '/' },
];
const breadcrumbs = [
  { label: 'Home', href: '/' },
];

const sections = [
  {
    country: 'China',
    flag: 'cn',
    cities: [
      { name: 'Zhuhai',    sub: '珠海',  href: '/china/zhuhai/gallery'    },
      { name: 'Guangzhou', sub: '广州',  href: '/china/guangzhou/gallery' },
      { name: 'Shenzhen',  sub: '深圳',  href: '/china/shenzhen/gallery'  },
      { name: 'Hong Kong', sub: '香港',  href: '/china/hongkong/gallery'  },
      { name: 'Macau',     sub: '澳门',  href: '/china/macau/gallery'     },
    ],
  },
  {
    country: 'Thailand',
    flag: 'th',
    cities: [
      { name: 'Bangkok',    sub: 'กรุงเทพฯ', href: '/thailand/bangkok/gallery'    },
      { name: 'Nonthaburi', sub: 'นนทบุรี',  href: '/thailand/nonthaburi/gallery' },
      { name: 'Koh Samet',  sub: 'เกาะเสม็ด', href: '/thailand/kohsamet/gallery'   },
    ],
  },
  {
    country: 'USA',
    flag: 'us',
    cities: [
      { name: 'Broomfield', sub: 'Colorado', href: '/usa/broomfield/gallery' },
      { name: 'Boulder',    sub: 'Colorado', href: '/usa/boulder/gallery'    },
      { name: 'Denver',     sub: 'Colorado', href: '/usa/denver/gallery'     },
    ],
  },
];
---
<MainLayout title="Full Gallery | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <!-- Triple-flag watermark (same as landing) -->
  <div slot="watermark" class="absolute inset-0 z-0 pointer-events-none flex items-start justify-between px-16 pt-10">
    <div class="opacity-15 transform scale-125 origin-top-left">
      <svg width="160" height="120" viewBox="0 0 300 200" fill="#F4E4BC">
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(1.5) translate(10,15)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,20) rotate(20)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,70) rotate(40)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(340,140) rotate(0)" />
        <polygon points="50,20 60,45 85,45 65,60 75,85 50,70 25,85 35,60 15,45 40,45" transform="scale(0.5) translate(280,190) rotate(-20)" />
      </svg>
    </div>
    <div class="opacity-15 blur-[1px] transform scale-125 origin-top">
      <svg width="160" height="120" viewBox="0 0 300 200" preserveAspectRatio="none">
        <rect width="300" height="33"  fill="#A51931" />
        <rect y="33"  width="300" height="33" fill="#F4F5F8" />
        <rect y="66"  width="300" height="68" fill="#2D2A4A" />
        <rect y="134" width="300" height="33" fill="#F4F5F8" />
        <rect y="167" width="300" height="33" fill="#A51931" />
      </svg>
    </div>
    <div class="opacity-15 blur-[1px] transform scale-125 origin-top-right">
      <svg width="160" height="120" viewBox="0 0 300 200" preserveAspectRatio="none">
        <rect width="300" height="200" fill="#B22234" />
        <rect y="15"   width="300" height="15" fill="#FFFFFF" />
        <rect y="45"   width="300" height="15" fill="#FFFFFF" />
        <rect y="75"   width="300" height="15" fill="#FFFFFF" />
        <rect y="105"  width="300" height="15" fill="#FFFFFF" />
        <rect y="135"  width="300" height="15" fill="#FFFFFF" />
        <rect y="165"  width="300" height="15" fill="#FFFFFF" />
        <rect width="120" height="107" fill="#3C3B6E" />
      </svg>
    </div>
  </div>

  <div class="flex flex-col items-center gap-12 w-full max-w-4xl pb-8">

    <div class="text-center">
      <h1 class="text-5xl font-bold text-[#F4E4BC] drop-shadow-md">Full Gallery</h1>
      <p class="text-xl text-[#E0F7FA] mt-2 font-medium tracking-wide">Every place. Every memory.</p>
    </div>

    {sections.map(section => (
      <div class="w-full">
        <h2 class="text-2xl font-bold text-[#F4E4BC] mb-4 border-b border-white/20 pb-2">{section.country}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5">
          {section.cities.map(city => (
            <a
              href={city.href}
              class="group flex flex-col items-center gap-3 p-4 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/20 hover:scale-105 transition-all duration-300"
            >
              <svg class="w-24 h-20" viewBox="0 0 96 78" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="16" width="92" height="60" rx="4" fill="#B8925A"/>
                <path d="M2 16 L2 9 Q2 7 5 7 L32 7 Q35 7 37 9 L43 16 Z" fill="#C9A06E"/>
                <rect x="2" y="24" width="92" height="52" rx="4" fill="#F4E4BC"/>
                <line x1="14" y1="38" x2="82" y2="38" stroke="#C9A06E" stroke-width="1.5" stroke-opacity="0.6"/>
                <line x1="14" y1="50" x2="82" y2="50" stroke="#C9A06E" stroke-width="1.5" stroke-opacity="0.6"/>
                <line x1="14" y1="62" x2="82" y2="62" stroke="#C9A06E" stroke-width="1.5" stroke-opacity="0.6"/>
              </svg>
              <div class="text-center">
                <p class="text-[#F4E4BC] font-bold text-base group-hover:text-white transition-colors leading-tight">{city.name}</p>
                <p class="text-[#E0F7FA] text-xs mt-0.5 opacity-70">{city.sub}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

  </div>

</MainLayout>

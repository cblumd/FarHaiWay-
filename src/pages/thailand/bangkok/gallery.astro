---
import MainLayout from '../../../layouts/MainLayout.astro';
const menuItems = [
  { label: 'Nonthaburi', href: '/thailand/nonthaburi' },
  { label: 'Koh Samet',  href: '/thailand/kohsamet'   },
  { separator: true },
  { label: '← Back to Bangkok', href: '/thailand/bangkok' },
];
const breadcrumbs = [
  { label: 'Home',     href: '/'                  },
  { label: 'Thailand', href: '/thailand'          },
  { label: 'Bangkok',  href: '/thailand/bangkok'  },
];
---
<MainLayout title="Gallery — Bangkok | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <div slot="watermark" class="absolute inset-0 z-0 opacity-15 grayscale blur-[60px] pointer-events-none mix-blend-multiply transform scale-110">
    <svg width="100%" height="100%" preserveAspectRatio="none">
      <rect width="100%" height="16.66%" fill="#A51931" />
      <rect y="16.66%" width="100%" height="16.66%" fill="#F4F5F8" />
      <rect y="33.33%" width="100%" height="33.33%" fill="#2D2A4A" />
      <rect y="66.66%" width="100%" height="16.66%" fill="#F4F5F8" />
      <rect y="83.33%" width="100%" height="16.66%" fill="#A51931" />
    </svg>
  </div>

  <div class="flex flex-col items-center gap-6">
    <a href="#" class="group hover:scale-105 transition-transform duration-300">
      <svg width="280" height="220" viewBox="0 0 96 78" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="16" width="92" height="60" rx="4" fill="#B8925A"/>
        <path d="M2 16 L2 9 Q2 7 5 7 L32 7 Q35 7 37 9 L43 16 Z" fill="#C9A06E"/>
        <rect x="2" y="24" width="92" height="52" rx="4" fill="#F4E4BC"/>
        <line x1="14" y1="38" x2="82" y2="38" stroke="#C9A06E" stroke-width="1.5" stroke-opacity="0.6"/>
        <line x1="14" y1="50" x2="82" y2="50" stroke="#C9A06E" stroke-width="1.5" stroke-opacity="0.6"/>
        <line x1="14" y1="62" x2="82" y2="62" stroke="#C9A06E" stroke-width="1.5" stroke-opacity="0.6"/>
      </svg>
    </a>
    <h1 class="text-5xl font-bold text-[#F4E4BC] drop-shadow-md">Gallery for Bangkok</h1>
    <p class="text-xl text-[#E0F7FA] font-medium tracking-wide">กรุงเทพฯ · 曼谷</p>
    <div class="mt-4 bg-white/10 px-8 py-4 rounded-xl backdrop-blur-sm border border-white/20 text-[#E0F7FA] text-center max-w-md">
      <p class="text-base">Google Drive link coming soon.</p>
      <p class="text-sm opacity-60 mt-1">Media will open in a view-only Drive folder.</p>
    </div>
  </div>

</MainLayout>

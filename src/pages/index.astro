---
import MainLayout from '../layouts/MainLayout.astro';

const menuItems = [
 { label: 'China', href: '/china' },
 { label: 'Thailand', href: '/thailand' },
 { label: 'USA', href: '/usa' },
 { separator: true },
 { label: 'Full Gallery', href: '/gallery' },
];

// Mock data for the destination cards based on your architecture
const destinations = [
 {
 title: "China",
 desc: "Ancient walls, sprawling megacities, and mist-covered mountains.",
 img: "https://images.unsplash.com/photo-1508804185872-d7bad800d9b1?q=80&w=800&auto=format&fit=crop",
 link: "/china"
 },
 {
 title: "Thailand",
 desc: "Golden temples, dense jungles, and the vibrant pulse of the streets.",
 img: "https://images.unsplash.com/photo-1552465011-b4e21bf6e79a?q=80&w=800&auto=format&fit=crop",
 link: "/thailand"
 },
 {
 title: "USA",
 desc: "Endless highways, rugged canyons, and diverse coastal shores.",
 img: "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=800&auto=format&fit=crop",
 link: "/usa"
 },
 {
 title: "Full Vault",
 desc: "Dive into the complete collection of untamed moments and raw footage.",
 img: "https://images.unsplash.com/photo-1455849318743-b2233052fcff?q=80&w=800&auto=format&fit=crop",
 link: "/gallery"
 }
];
---

<MainLayout title="FarHaiWay" menuItems={menuItems}>
 <!-- Triggers for Peer Logic (Kept your existing trilingual architecture) -->
 <input type="radio" name="lang-peer" id="lang-en" class="peer/en hidden" checked />
 <input type="radio" name="lang-peer" id="lang-th" class="peer/th hidden" />
 <input type="radio" name="lang-peer" id="lang-ch" class="peer/ch hidden" />

 <!-- Global Dark Theme Wrapper -->
 <div class="min-h-screen bg-[#121212] text-gray-300 font-sans selection:bg-[#800000] selection:text-[#C5A059]">
 
 <!-- Hero Section -->
 <section class="relative w-full h-[65vh] flex items-center justify-center overflow-hidden border-b border-[#C5A059]/20">
 <!-- Moody Background Image (Misty temple/ruins) -->
 <div class="absolute inset-0">
 <img 
 src="https://images.unsplash.com/photo-1518709268805-4e9042af9f23?q=80&w=2000&auto=format&fit=crop" 
 alt="Ancient misty landscape" 
 class="w-full h-full object-cover opacity-40 mix-blend-luminosity grayscale-[30%]"
 />
 <!-- Dark gradient overlays to blend into the background -->
 <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/70 via-transparent to-[#121212]"></div>
 <div class="absolute inset-0 bg-gradient-to-t from-[#121212] via-transparent to-transparent h-full"></div>
 </div>

 <!-- Hero Content -->
 <div class="relative z-10 text-center px-6 flex flex-col items-center">
 <!-- English -->
 <div class="hidden peer-checked/en:block animate-fade-in">
 <h1 class="font-serif text-5xl md:text-7xl font-semibold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)] tracking-wide">
 FarHaiWay
 </h1>
 <p class="text-sm md:text-base text-gray-400 mt-4 tracking-[0.2em] uppercase">
 Check out my adventures
 </p>
 </div>

 <!-- Thai -->
 <div class="hidden peer-checked/th:block animate-fade-in">
 <h1 class="font-serif text-5xl md:text-7xl font-semibold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)] tracking-wide">
 FarHaiWay
 </h1>
 <p class="text-sm md:text-base text-gray-400 mt-4 tracking-[0.1em] uppercase">
 ตรวจสอบการผจญภัยของฉัน
 </p>
 </div>

 <!-- Chinese -->
 <div class="hidden peer-checked/ch:block animate-fade-in">
 <h1 class="font-serif text-5xl md:text-7xl font-semibold text-[#C5A059] drop-shadow-[0_4px_10px_rgba(0,0,0,0.9)] tracking-widest">
 远海之路
 </h1>
 <p class="text-sm md:text-base text-gray-400 mt-4 tracking-[0.2em] uppercase">
 看看我的冒险
 </p>
 </div>

 <!-- Call to Action Button -->
 <a href="/gallery" class="mt-10 px-8 py-3 bg-[#800000]/80 hover:bg-[#800000] text-[#C5A059] border border-[#B87333]/50 hover:border-[#C5A059] transition-all duration-300 font-serif tracking-wider text-sm shadow-[0_0_20px_rgba(128,0,0,0.3)] backdrop-blur-sm">
 Explore Recent Entries
 </a>
 </div>
 </section>

 <!-- Destinations Grid Section -->
 <section class="max-w-5xl mx-auto px-6 py-16 md:py-24">
 <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
 
 {destinations.map((dest) => (
 <a href={dest.link} class="group flex flex-col sm:flex-row bg-[#1a1a1a] border border-[#2a2a2a] hover:border-[#C5A059]/40 transition-all duration-500 rounded-sm overflow-hidden shadow-lg hover:shadow-[0_4px_20px_rgba(0,0,0,0.5)]">
 <!-- Thumbnail -->
 <div class="w-full sm:w-2/5 h-48 sm:h-auto overflow-hidden relative">
 <div class="absolute inset-0 bg-[#121212]/20 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
 <img 
 src={dest.img} 
 alt={dest.title}
 class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 opacity-80 group-hover:opacity-100 mix-blend-luminosity group-hover:mix-blend-normal"
 />
 </div>
 
 <!-- Card Content -->
 <div class="w-full sm:w-3/5 p-6 flex flex-col justify-center">
 <h3 class="font-serif text-xl md:text-2xl text-[#C5A059] mb-3 group-hover:text-[#d4b475] transition-colors">
 {dest.title}
 </h3>
 <p class="text-sm text-gray-400 leading-relaxed mb-4 line-clamp-3">
 {dest.desc}
 </p>
 <span class="text-[#800000] text-sm font-semibold tracking-wider group-hover:text-[#a00000] transition-colors flex items-center gap-2">
 Read More 
 <span class="transform group-hover:translate-x-1 transition-transform">→</span>
 </span>
 </div>
 </a>
 ))}

 </div>
 </section>
 </div>
</MainLayout>

<style>
 /* Import the sophisticated Serif font directly into Astro */
 @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');

 .font-serif {
 font-family: 'Playfair Display', serif;
 }

 .animate-fade-in {
 animation: fadeIn 1s ease-out forwards;
 }

 @keyframes fadeIn {
 from { opacity: 0; transform: translateY(10px); }
 to { opacity: 1; transform: translateY(0); }
 }
</style>
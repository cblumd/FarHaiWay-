---
/**
 * MainLayout.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Shared shell for every FarHaiWay page. Provides:
 *   • Ocean-teal gradient background
 *   • Fixed palm-tree SVGs (bottom corners, opacity-40)
 *   • Hamburger nav + configurable dropdown menu
 *   • 3-way language toggle (EN / TH / CH) — pure CSS peer trick
 *   • Named slot "watermark" for country-specific SVG overlays
 *   • Default slot for all per-page content
 *
 * Props
 * ─────
 *   title       string              <title> tag text
 *   menuItems   MenuItem[]          Hamburger dropdown links (optional)
 *   breadcrumbs Breadcrumb[]        Breadcrumb trail shown top-right (optional)
 *
 * Types
 * ─────
 *   MenuItem   { label: string, href: string } | { separator: true }
 *   Breadcrumb { label: string, href: string }
 */

export interface MenuItem {
  label?: string;
  href?: string;
  separator?: boolean;
}
export interface Breadcrumb {
  label: string;
  href: string;
}
interface Props {
  title: string;
  menuItems?: MenuItem[];
  breadcrumbs?: Breadcrumb[];
}
const { title, menuItems = [], breadcrumbs = [] } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body class="font-sans">

  <div class="min-h-screen bg-gradient-to-br from-[#006994] to-[#E0F7FA] p-8 overflow-hidden relative">

    <!-- ── Country/region watermark (named slot) ─────────────────────────── -->
    <slot name="watermark" />

    <!-- ── Palm tree — LEFT ──────────────────────────────────────────────── -->
    <div class="absolute -left-10 -bottom-10 opacity-40 pointer-events-none transform scale-110 z-0">
      <svg width="300" height="400" viewBox="0 0 100 140" fill="none"
           stroke="#9DC183" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M45 140 Q30 80 45 30" />
        <path d="M55 140 Q40 80 45 30" />
        <path d="M42 120 L52 120" />
        <path d="M39 100 L49 100" />
        <path d="M38 80 L46 80" />
        <path d="M40 60 L45 60" />
        <path d="M42 45 L46 45" />
        <path d="M45 30 Q15 10 0 35" />
        <path d="M45 30 Q80 15 95 30" />
        <path d="M45 30 Q10 40 5 70" />
        <path d="M45 30 Q85 45 85 75" />
        <path d="M45 30 Q25 65 30 90" />
        <path d="M45 30 Q65 65 60 90" />
        <path d="M45 30 Q45 -5 60 10" />
      </svg>
    </div>

    <!-- ── Palm tree — RIGHT (mirrored + rotated) ────────────────────────── -->
    <div class="absolute -right-10 -bottom-10 opacity-40 pointer-events-none transform scale-110 -scale-x-100 rotate-6 z-0">
      <svg width="300" height="400" viewBox="0 0 100 140" fill="none"
           stroke="#9DC183" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M45 140 Q30 80 45 30" />
        <path d="M55 140 Q40 80 45 30" />
        <path d="M42 120 L52 120" />
        <path d="M39 100 L49 100" />
        <path d="M38 80 L46 80" />
        <path d="M40 60 L45 60" />
        <path d="M42 45 L46 45" />
        <path d="M45 30 Q15 10 0 35" />
        <path d="M45 30 Q80 15 95 30" />
        <path d="M45 30 Q10 40 5 70" />
        <path d="M45 30 Q85 45 85 75" />
        <path d="M45 30 Q25 65 30 90" />
        <path d="M45 30 Q65 65 60 90" />
        <path d="M45 30 Q45 -5 60 10" />
      </svg>
    </div>

    <!-- ── Hamburger checkbox — MUST come before nav for peer/menu to work ─ -->
    <input type="checkbox" id="menu-toggle" class="peer/menu hidden" />

    <!-- ── Nav bar ────────────────────────────────────────────────────────── -->
    <nav class="relative z-30 flex justify-between items-center text-[#F4E4BC]">
      <label for="menu-toggle" class="text-3xl font-bold cursor-pointer hover:text-white select-none">☰</label>

      <div class="flex flex-col items-end gap-2 font-bold">
        <!-- Breadcrumbs -->
        {breadcrumbs.length > 0 && (
          <div class="flex gap-4">
            {breadcrumbs.map((b: Breadcrumb) => (
              <a href={b.href} class="hover:underline text-lg">{b.label}</a>
            ))}
          </div>
        )}

        <!-- Language toggle -->
        <div class="flex gap-4 border border-[#F4E4BC]/30 p-1 px-3 rounded-full text-sm bg-[#006994]/20 backdrop-blur-sm">
          <label for="lang-en" class="cursor-pointer hover:underline select-none">EN</label>
          <label for="lang-th" class="cursor-pointer hover:underline select-none">TH</label>
          <label for="lang-ch" class="cursor-pointer hover:underline select-none">CH</label>
        </div>
      </div>
    </nav>

    <!-- ── Hamburger dropdown ─────────────────────────────────────────────── -->
    {menuItems.length > 0 && (
      <div class="hidden peer-checked/menu:block absolute top-28 left-8 z-30 bg-[#F4E4BC] p-6 rounded-lg text-[#006994] shadow-xl w-48 border border-[#F4E4BC]/50">
        <ul class="space-y-4 font-bold text-lg">
          {menuItems.map((item: MenuItem) =>
            item.separator
              ? <hr class="border-[#006994] opacity-30 my-2" />
              : <li><a href={item.href} class="hover:text-black block">{item.label}</a></li>
          )}
        </ul>
      </div>
    )}


    <!-- ── Per-page content ───────────────────────────────────────────────── -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-[70vh] text-center mt-4">
      <slot />
    </div>

  </div>
</body>
</html>

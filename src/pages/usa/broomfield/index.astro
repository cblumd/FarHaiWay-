---
import MainLayout from '../../../layouts/MainLayout.astro';

const menuItems = [
  { label: 'Boulder', href: '/usa/boulder' },
  { label: 'Denver',  href: '/usa/denver'  },
  { separator: true },
  { label: 'Gallery', href: '/usa/broomfield/gallery' },
];

const breadcrumbs = [
  { label: 'Home', href: '/'    },
  { label: 'USA',  href: '/usa' },
];
---
<MainLayout title="Broomfield | FarHaiWay" menuItems={menuItems} breadcrumbs={breadcrumbs}>

  <div slot="watermark" class="absolute inset-0 z-0 opacity-15 blur-2xl pointer-events-none mix-blend-multiply transform scale-110">
    <svg width="100%" height="100%" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="#B22234" />
      <rect y="7.69%"  width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="23.07%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="38.46%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="53.84%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="69.23%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect y="84.61%" width="100%" height="7.69%" fill="#FFFFFF" />
      <rect width="40%" height="53.84%" fill="#3C3B6E" />
    </svg>
  </div>

  <!-- EN -->
  <div class="hidden peer-checked/en:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">Broomfield</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">Home Between the Mountains</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[Enter text here]</p>
      <p class="text-lg leading-relaxed">[Enter text here]</p>
    </div>
    <a href="/usa/broomfield/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 View Gallery
    </a>
  </div>

  <!-- TH -->
  <div class="hidden peer-checked/th:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">บรูมฟิลด์</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">บ้านระหว่างขุนเขา</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[กรอกข้อความที่นี่]</p>
      <p class="text-lg leading-relaxed">[กรอกข้อความที่นี่]</p>
    </div>
    <a href="/usa/broomfield/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 ดูแกลเลอรี่
    </a>
  </div>

  <!-- CH -->
  <div class="hidden peer-checked/ch:flex flex-col items-center">
    <h1 class="text-7xl font-bold text-[#F4E4BC] drop-shadow-md">布鲁姆菲尔德</h1>
    <p class="text-2xl text-[#E0F7FA] mt-4 font-medium tracking-wide">山间的家</p>
    <div class="max-w-2xl mt-12 bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 text-white text-left shadow-lg">
      <p class="text-lg leading-relaxed mb-4">[在此输入文字]</p>
      <p class="text-lg leading-relaxed">[在此输入文字]</p>
    </div>
    <a href="/usa/broomfield/gallery" class="mt-8 flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-[#F4E4BC] font-bold px-6 py-3 rounded-xl backdrop-blur-sm transition-all">
      📁 查看图库
    </a>
  </div>

</MainLayout>
